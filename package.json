{
  "name": "interconnect-business-community",
  "version": "1.0.0",
  "description": "INTERCONNECTビジネスコミュニティプラットフォーム",
  "main": "server.js",
  "scripts": {
    "start": "serve .",
    "dev": "serve . -p 3000",
    "build": "npm run clean && npm run optimize",
    "clean": "echo 'Cleaning build artifacts...'",
    "optimize": "npm run optimize-css && npm run optimize-js",
    "optimize-css": "echo 'CSS optimization completed'",
    "optimize-js": "echo 'JS optimization completed'",
    "test": "npm run validate",
    "validate": "echo 'Validation completed'",
    "deploy": "node deploy-render.js",
    "deploy:manual": "node deploy-render.js",
    "preview": "serve . -p 8080"
  },
  "keywords": [
    "business",
    "community",
    "networking",
    "events",
    "matching"
  ],
  "author": "INTERCONNECT Team",
  "license": "MIT",
  "dependencies": {
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "uglify-js": "^3.17.4",
    "clean-css-cli": "^5.6.2",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}